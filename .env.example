# Sentinel AI configuration -- copy to `.env` for local development.
# Nested groups use a double-underscore delimiter: SENTINEL_<GROUP>__<FIELD>.

SENTINEL_ENVIRONMENT=local
SENTINEL_SERVICE_NAME=sentinel
SENTINEL_INTERSECTION_ID=intersection-1

# --- RabbitMQ (inter-agent event bus) ---
SENTINEL_RABBITMQ__HOST=localhost
SENTINEL_RABBITMQ__PORT=5672
SENTINEL_RABBITMQ__USERNAME=guest
SENTINEL_RABBITMQ__PASSWORD=guest
SENTINEL_RABBITMQ__EXCHANGE=sentinel.events

# --- Redis (live state + stream deltas) ---
SENTINEL_REDIS__HOST=localhost
SENTINEL_REDIS__PORT=6379
SENTINEL_REDIS__STATE_TTL_S=30

# --- PostgreSQL (history / audit) ---
SENTINEL_POSTGRES__HOST=localhost
SENTINEL_POSTGRES__PORT=5432
SENTINEL_POSTGRES__DATABASE=sentinel
SENTINEL_POSTGRES__USERNAME=sentinel
SENTINEL_POSTGRES__PASSWORD=sentinel

# --- Observability ---
SENTINEL_OBS__LOG_LEVEL=INFO
SENTINEL_OBS__LOG_JSON=true
SENTINEL_OBS__METRICS_PORT=9100
SENTINEL_OBS__TRACING_ENABLED=false

# --- Decision safety envelope ---
SENTINEL_DECISION__MIN_GREEN_S=7
SENTINEL_DECISION__MAX_GREEN_S=60
SENTINEL_DECISION__YELLOW_S=3
SENTINEL_DECISION__ALL_RED_S=2
SENTINEL_DECISION__NO_MOVEMENT_SWITCH_S=18
SENTINEL_DECISION__QUEUE_CONGESTION_THRESHOLD_M=15

# --- Perception ---
SENTINEL_PERCEPTION__MODEL_PATH=models/weights/yolo.pt
SENTINEL_PERCEPTION__DEVICE=cuda:0
SENTINEL_PERCEPTION__TARGET_FPS=10
